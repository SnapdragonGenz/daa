#include <stdio.h>

void swap(int *a, int *b)
{
    int temp = *a;
    *a = *b;
    *b = temp;
}

int hoarePartition(int A[], int l, int r)
{
    int p = A[l];
    int i = l;
    int j = r + 1;

    while (1)
    {
        do {
            i = i + 1;
        } while (i <= r && A[i] < p);

        do {
            j = j - 1;
        } while (j >= l && A[j] > p);

        if (i >= j)
            break;

        swap(&A[i], &A[j]);
    }

    swap(&A[l], &A[j]);
    return j;
}


void quickSort(int A[], int l, int r)
{
    if (l < r)
    {
        int s = hoarePartition(A, l, r);
        quickSort(A, l, s - 1);
        quickSort(A, s + 1, r);
    }
}
