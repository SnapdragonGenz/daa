#include <stdio.h>

int main()
{
    int n, i, j, min, next, pos = 0, total = 0;
    int cost[10][10], visited[10];

    // where,
    // n = number of cities
    // cost = cost between cities
    // visited = checks if city has been visited
    // pos = current city
    // next = next city
    // total = total travel cost

    printf("Enter value of n: ");
    scanf("%d", &n);

    if (n <= 0)   // invalid input check
    {
        printf("Invalid input");
        return 0;
    }

    printf("Enter cost matrix:\n");
    for(i = 0; i < n; i++)
        for(j = 0; j < n; j++)
            scanf("%d", &cost[i][j]);

    for(i = 0; i < n; i++)
        visited[i] = 0;  // Mark all cities as not visited

    visited[0] = 1;   // Start from city 1
    printf("Path: 1");

    for(i = 1; i < n; i++)
    {
        min = 999;

        for(j = 0; j < n; j++)
        {
            if(visited[j] == 0 && cost[pos][j] < min && cost[pos][j] != 0)
            {
                min = cost[pos][j];
                next = j;
            }
        }

        total = total + min;
        pos = next;
        visited[pos] = 1;
        printf(" -> %d", pos + 1);
    }

    total = total + cost[pos][0];   // Return to starting city
    printf(" -> 1");

    printf("\nMinimum cost = %d", total);

    return 0;
}
