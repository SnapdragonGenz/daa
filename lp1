
#include <stdio.h>

int main() {
    int a[50], n, key, l = 0, r, mid, i;

    printf("Enter size: ");
    scanf("%d", &n);

    printf("Enter sorted elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    printf("Enter key: ");
    scanf("%d", &key);

    r = n - 1;

    while(l <= r) {
        mid = (l + r) / 2;

        if(a[mid] == key) {
            printf("Found at %d", mid);
            return 0;
        }
        else if(key < a[mid])
            r = mid - 1;
        else
            l = mid + 1;
    }

    printf("Not found");
    return 0;
}
