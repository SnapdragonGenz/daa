#include <stdio.h>
int main()
{
    int n, i, j, sum, target, set[20], found=0; 
    printf("Enter number of elements: ");   
    scanf("%d", &n);
    printf("Enter elements:\n");            
    for(i = 0; i < n; i++)
        scanf("%d", &set[i]);
    printf("Enter target sum: ");  
    scanf("%d", &target);
    for(i = 0; i < (1 << n); i++)   


    {
        sum = 0;
        for(j = 0; j < n; j++)   
        {
            if(i & (1 << j))   
                sum += set[j];
        }
        if(sum == target)
        {
            found = 1;
            printf("Subset: ");
            for(j = 0; j < n; j++)
            {
                if(i & (1 << j))
                    printf("%d ", set[j]);
            }
            printf("\n");
        }
    }
    if(found == 0)   //If none of the subsets match the target, tell the user.
        printf("Subset not found");
    return 0;
}
