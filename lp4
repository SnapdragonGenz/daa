#include <stdio.h>
int main()
{
 int n, x, i, a[20], result;
 printf("Enter number of terms: ");
 scanf("%d", &n);
 printf("Enter coefficients:\n");
 for (i = 0; i < n; i++)
 scanf("%d", &a[i]);
 printf("Enter value of x: ");
 scanf("%d", &x);
 result = a[0];
 for (i = 1; i < n; i++)
 result = result * x + a[i];
 printf("Result = %d", result);
 return 0;
}
