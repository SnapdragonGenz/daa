#include <stdio.h>
int main()
{
    int n, i, j, min, total=0, edges=0, a=0, b=0, cost[10][10], visited[10] = {0};
    printf("Enter number of vertices: ");
    scanf("%d", &n);
     if(n <= 0)
    {
        printf("Invalid input");
        return 0;
    }
    printf("Enter cost matrix:\n");
    for(i = 0; i < n; i++)
    {
        for(j = 0; j < n; j++)
        {
            scanf("%d", &cost[i][j]);
            if(cost[i][j] == 0)
                cost[i][j] = 999;
        }
    }
    visited[0] = 1;   //start from vertex 0
    printf("\nEdges in Minimum Spanning Tree:\n");
    while(edges < n-1)
    {
        min = 999; 
        for(i = 0; i < n; i++)
        {
            if(visited[i] == 1)
            {
                for(j = 0; j < n; j++)
                {
                    if(visited[j] == 0 && cost[i][j] < min)
                    {
                        min = cost[i][j];
                        a = i;
                        b = j;
                    }
                }
            }
        } 
        printf("%d - %d = %d\n", a, b, min);
        visited[b] = 1;
        total = total + min;
        edges++;
    }
    printf("Total cost = %d", total);
    return 0;
}
